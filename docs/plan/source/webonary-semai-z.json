        "definitionorgloss": [
          {
            "lang": "ms",
            "value": "bunyi sesuatu meluru dengan pantas dan laju"
          },
          {
            "lang": "en",
            "value": "sound of something rushing fast"
          }
        ],
        "examplescontents": [
          {
            "example": [
              {
                "lang": "sea",
                "value": "Bah Amat ki en imutu had inelaju, zup…, tok dan eng ngterhan ilei."
              }
            ],
            "translationcontents": [
              {
                "translation": [
                  {
                    "lang": "ms",
                    "value": "Bah Amat membawa motosikalnya terlalu laju, zup..., tidak sempat saya mahu menahannya. "
                  },
                  {
                    "lang": "en",
                    "value": "Bah Amat drove his motorcycle too quickly; zoom! ... I couldn't stand it!"
                  }
                ]
              }
            ]
          }
        ]
