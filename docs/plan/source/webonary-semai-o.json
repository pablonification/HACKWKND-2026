        "examplescontents": [
          {
            "example": [
              {
                "lang": "sea",
                "value": "\"Baju ajeh biog ya Bah Nan ha hek,\" Wak Jari kiurok nu Wak Mila."
              }
            ],
            "translationcontents": [
              {
                "translation": [
                  {
                    "lang": "ms",
                    "value": "\"Baju tersebut diberi oleh Bah Nan bagi kamu,\" Wak Jari berkata kepada Wak Mila."
                  },
                  {
                    "lang": "en",
                    "value": "\"The shirt was given by Bah Nan for you,\" Wak Jari said to Wak Mila."
                  }
