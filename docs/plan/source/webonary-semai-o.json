        "guid": "gcd147db0-8f6a-4e78-a3a5-7eaee92024d0",
        "definitionorgloss": [
          {
            "lang": "ms",
            "value": "entah"
          },
          {
            "lang": "en",
            "value": "word to express that one does not know, perhaps, maybe"
          }
        ],
        "examplescontents": [
          {
            "example": [
              {
                "lang": "sea",
                "value": "\"Oh,\" Bah Gurek kiberlag bile bitanya belok imemenang ya iamek."
              }
            ],
            "translationcontents": [
              {
                "translation": [
                  {
                    "lang": "ms",
                    "value": "\"Entah,\" Bah Gurek menjawab bila ibunya bertanya ke mana adik-adiknya pergi."
                  },
                  {
                    "lang": "en",
                    "value": "\"I don't know,\" Bah Gurek replied when his mother asked where his siblings had gone."
                  }
                ]
              }
            ]
          }
        ]
      }
    ],
