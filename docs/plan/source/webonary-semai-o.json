            "examplescontents-2": [
              {
                "example-2": [
                  {
                    "lang": "sea",
                    "value": "Jam adeh ennog ju amek eng."
                  }
                ],
                "translationcontents-2": [
                  {
                    "translation-2": [
                      {
                        "lang": "ms",
                        "value": "Jam ini pemberian dari ibu saya."
                      },
                      {
                        "lang": "en",
                        "value": "This watch is a gift from my mother."
                      }
                    ]
                  }
                ]
              },
              {
