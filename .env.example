# =========================
# Supabase
# =========================
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
VITE_PASSWORD_RESET_REDIRECT_TO=https://your-domain.com/reset-password

# =========================
# AI Backend
# =========================
VITE_AI_BASE_URL=http://localhost:8787

# =========================
# Capacitor Dev Server
# =========================
CAPACITOR_DEV_SERVER_URL=http://your-local-ip:5173

# =========================
# ElevenLabs (Text to Speech)
# =========================
ELEVENLABS_API_KEY=your-elevenlabs-api-key
ELEVENLABS_VOICE_ID=your-elevenlabs-voice-id
ELEVENLABS_MODEL_ID=eleven_multilingual_v2
ELEVENLABS_OUTPUT_FORMAT=mp3_44100_128

# =========================
# AI Providers
# =========================
GOOGLE_AI_STUDIO_API_KEY=your-google-ai-studio-api-key
AI_COACH_GEMINI_MODEL=gemini-3.1-flash-lite-preview

