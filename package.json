{
  "name": "taleka-mobile",
  "version": "1.0.0",
  "private": true,
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "lint": "eslint . --max-warnings=0",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "check": "npm run lint && npm run format:check && npm run typecheck && npm run test -- --bail",
    "prepare": "husky",
    "precommit": "lint-staged && npm run typecheck && npm run test -- --bail"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix --max-warnings=0",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/native": "^7.1.31",
    "@react-navigation/native-stack": "^7.14.2",
    "@supabase/supabase-js": "^2.98.0",
    "expo": "~55.0.4",
    "expo-font": "~55.0.4",
    "expo-status-bar": "~55.0.4",
    "nativewind": "^4.2.2",
    "react": "19.2.0",
    "react-native": "0.83.2",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-url-polyfill": "^3.0.0"
  },
  "devDependencies": {
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "29.5.14",
    "@types/react": "~19.2.2",
    "babel-preset-expo": "^55.0.10",
    "eslint": "^9.39.3",
    "eslint-config-expo": "^55.0.0",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "jest-expo": "^55.0.9",
    "lint-staged": "^16.3.1",
    "prettier": "^3.8.1",
    "react-test-renderer": "^19.2.0",
    "tailwindcss": "^3.4.19",
    "typescript": "~5.9.2"
  }
}
